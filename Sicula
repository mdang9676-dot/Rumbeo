-- Biến lưu giá trị FOV
local aimFovValue = 360
local targetPlayer = nil

aimFovTextBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local value = tonumber(aimFovTextBox.Text)
        if value and value > 0 and value <= 360 then
            aimFovValue = value
        else
            aimFovTextBox.Text = ""
            aimFovTextBox.PlaceholderText = "Max 360"
        end
    end
end)

aimFovButton.MouseButton1Click:Connect(function()
    aimFovEnabled = not aimFovEnabled
    aimFovButton.Text = aimFovEnabled and "AimFov: ON" or "AimFov: OFF"
    aimFovButton.BackgroundColor3 = aimFovEnabled and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(50, 50, 50)
end)

-- Hàm lấy người chơi gần nhất trong FOV
local function getClosestPlayerInFov()
    local closestPlayer = nil
    local shortestDistance = aimFovValue
    local camera = workspace.CurrentCamera
    
    if not camera then return nil end
    
    for _, v in pairs(players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
            local head = v.Character:FindFirstChild("Head")
            if head then
                local screenPos, onScreen = camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local mousePos = Vector2.new(mouse.X, mouse.Y)
                    local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closestPlayer = v
                    end
                end
            end
        end
    end
    
    return closestPlayer
end

