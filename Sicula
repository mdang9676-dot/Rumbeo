-- Hàm tấn công
local function attackTarget(target)
    if not target or not target.Character then return end
    
    local character = player.Character
    if not character then return end
    
    -- Cố gắng sử dụng các tool/weapon có sẵn
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then
        -- Mô phỏng click để tấn công
        local args = {
            [1] = target.Character
        }
        
        -- Thử các remote event phổ biến trong game Jujutsu
        local replicatedStorage = game:GetService("ReplicatedStorage")
        
        -- Tìm kiếm và gọi remote attack
        for _, remote in pairs(replicatedStorage:GetDescendants()) do
            if remote:IsA("RemoteEvent") and (remote.Name:lower():find("attack") or remote.Name:lower():find("hit") or remote.Name:lower():find("combat")) then
                pcall(function()
                    remote:FireServer(unpack(args))
                end)
            end
        end
    end
end

