-- Biến lưu trạng thái dodge
local lastDodgeTime = 0
local dodgeCooldown = 2

-- Hàm dodge
local function performDodge()
    local character = player.Character
    if not character then return end
    
    local currentTime = tick()
    if currentTime - lastDodgeTime < dodgeCooldown then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    
    if humanoid and rootPart then
        -- Tạo hướng dodge ngẫu nhiên
        local dodgeDirection = Vector3.new(math.random(-1, 1), 0, math.random(-1, 1)).Unit
        local dodgeForce = dodgeDirection * 50
        
        -- Áp dụng dodge
        rootPart.Velocity = rootPart.Velocity + dodgeForce
        
        -- Gọi remote dodge nếu có
        local replicatedStorage = game:GetService("ReplicatedStorage")
        for _, remote in pairs(replicatedStorage:GetDescendants()) do
            if remote:IsA("RemoteEvent") and (remote.Name:lower():find("dodge") or remote.Name:lower():find("dash") or remote.Name:lower():find("evade")) then
                pcall(function()
                    remote:FireServer()
                end)
            end
        end
        
        lastDodgeTime = currentTime
    end
end

-- Hàm phát hiện skill đang bay tới
local function isSkillIncoming()
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    
    local rootPart = character.HumanoidRootPart
    
    -- Quét các object có thể là skill (projectile, effect, etc)
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Velocity.Magnitude > 10 then
            -- Kiểm tra xem object có đang bay về phía người chơi không
            local toObject = (obj.Position - rootPart.Position).Unit
            local objectDirection = obj.Velocity.Unit
            
            -- Nếu object đang di chuyển về phía người chơi
            local dotProduct = toObject:Dot(objectDirection)
            if dotProduct < -0.3 then
                local distance = (obj.Position - rootPart.Position).Magnitude
                if distance < 30 then -- Trong phạm vi 30 studs
                    return true
                end
            end
        end
    end
    
    return false
end

