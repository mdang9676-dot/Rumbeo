--// --------------- ESP FUNCTIONS ---------------
local function GetDistanceColor(dist)
    local t = math.clamp(dist / ESP.MaxDistance, 0, 1)
    return Color3.fromRGB(255 * (1-t), 255 * t, 0)
end

local function DrawBox(obj, color)
    if not obj:IsA("Model") and not obj:IsA("Part") then return end
    local highlight = obj:FindFirstChild("ESP_Box")
    if highlight then highlight:Destroy() end
    highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Box"
    highlight.FillTransparency = 1
    highlight.OutlineColor = color
    highlight.OutlineTransparency = 0
    highlight.Parent = obj
end

local function DrawTracer(start, endPos, color)
    local part = Instance.new("Part")
    part.Name = "ESP_Tracer"
    part.Anchored = true
    part.CanCollide = false
    part.Size = Vector3.new(0.1, 0.1, (start - endPos).Magnitude)
    part.CFrame = CFrame.new((start + endPos) / 2, endPos)
    part.BrickColor = BrickColor.new(color)
    part.Material = Enum.Material.Neon
    part.Parent = workspace
    return part
end

local function DrawHealthBar(part, healthPercent)
    local billboard = part:FindFirstChild("ESP_HealthBar")
    if billboard then billboard:Destroy() end
    if healthPercent < 0 then return end
    billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_HealthBar"
    billboard.Size = UDim2.new(4, 0, 0.4, 0)
    billboard.AlwaysOnTop = true
    billboard.Adornee = part
    local bar = Instance.new("Frame", billboard)
    bar.Size = UDim2.new(1, 0, healthPercent, 0)
    bar.BackgroundColor3 = Color3.fromRGB(255 * (1-healthPercent), 255 * healthPercent, 0)
    bar.BorderSizePixel = 0
    billboard.Parent = part
end

local function CreatePlayerESP(player)
    local char = player.Character
    if not char or not LocalPlayer.Character then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not root then return end

    local boxToggle = Window.Flags["Player Box"]
    local tracerToggle = Window.Flags["Player Tracers"]
    local distToggle = Window.Flags["Player Distance"]
    local weaponToggle = Window.Flags["Player Weapon"]

    if boxToggle then DrawBox(char, ESP.BoxColor) end
    if tracerToggle then
        local tracer = DrawTracer(Camera.CFrame.Position, root.Position, ESP.BoxColor)
        game.Debris:AddItem(tracer, 0.1)
    end

    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid and Window.Flags["Player Health Bar"] then
        DrawHealthBar(root, humanoid.Health / humanoid.MaxHealth)
    end

    if distToggle then
        local billboard = root:FindFirstChild("ESP_Distance")
        if not billboard then
            billboard = Instance.new("BillboardGui", root)
            billboard.Name = "ESP_Distance"
            billboard.Size = UDim2.new(0, 100, 0, 30)
            billboard.StudsOffset = Vector3.new(0, 3, 0)
            billboard.AlwaysOnTop = true
            local label = Instance.new("TextLabel", billboard)
            label.Size = UDim2.new(1,0,1,0)
            label.BackgroundTransparency = 1
            label.TextScaled = true
            label.TextColor3 = Color3.new(1,1,1)
            label.Font = Enum.Font.SourceSansBold
        end
        local dist = (LocalPlayer.Character.HumanoidRootPart.Position - root.Position).Magnitude
        billboard.TextLabel.Text = tostring(math.floor(dist)).."m"
        billboard.TextLabel.TextColor3 = GetDistanceColor(dist)
    end

    if weaponToggle then
        local tool = char:FindFirstChildOfClass("Tool")
        -- weapon display simplified, you can add a billboard for it.
    end
end

--// Refresh Player ESP
function RefreshPlayerESP()
    for _, v in pairs(ESPObjects.Players) do if v then v:Destroy() end end
    table.clear(ESPObjects.Players)
    if not Window.Flags["Player ESP"] then return end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            CreatePlayerESP(player)
        end
    end
end

